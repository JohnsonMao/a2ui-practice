        },
        "prefs": {
          "darkMode": false,
          "autoSave": true,
          "language": ["zh-TW"],
          "fontSize": 16
        },
        "notif": {
          "email": true,
          "push": true,
          "sms": false,
          "frequency": ["realtime"]
        }
      }
    }
  },
