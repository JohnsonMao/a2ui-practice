{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": ["^typecheck"]
        },
        "test": {
            "dependsOn": ["^build"]
        },
        "test:e2e": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "coverage": {
            "dependsOn": ["^build"],
            "outputs": ["coverage/**"]
        }
    }
}
